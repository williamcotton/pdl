{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "PDL",
  "scopeName": "source.pdl",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#functions"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.pdl",
          "match": "//.*$"
        },
        {
          "name": "comment.block.pdl",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.pdl",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.pdl",
              "match": "\\\\(?:[\"\\\\nrt]|u\\{[0-9A-Fa-f]+\\})"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.pdl",
          "match": "\\b[0-9]+(?:\\.[0-9]+)?(?:[eE][+-]?[0-9]+)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.pdl",
          "match": "\\|"
        },
        {
          "name": "keyword.operator.comparison.pdl",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.arithmetic.pdl",
          "match": "[+\\-*/%]"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.pdl",
          "match": "\\b(?:let|load|filter|select|drop|rename|mutate|group_by|agg|sort|limit|join|union|distinct|save|as|on|kind|format|stdin|stdout|and|or|not|asc|desc|nulls_first|nulls_last)\\b"
        },
        {
          "name": "constant.language.pdl",
          "match": "\\b(?:true|false|null)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "support.function.aggregate.pdl",
          "match": "\\b(?:count|sum|mean|min|max)\\b(?=\\s*\\()"
        }
      ]
    }
  }
}
