{
  "comments": {
    "lineComment": "//",
    "blockComment": [
      "/*",
      "*/"
    ]
  },
  "brackets": [
    [
      "(",
      ")"
    ]
  ],
  "autoClosingPairs": [
    {
      "open": "\"",
      "close": "\""
    },
    {
      "open": "`",
      "close": "`"
    },
    {
      "open": "(",
      "close": ")"
    }
  ],
  "surroundingPairs": [
    {
      "open": "\"",
      "close": "\""
    },
    {
      "open": "`",
      "close": "`"
    },
    {
      "open": "(",
      "close": ")"
    }
  ],
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([^`~!@#$%^&*()+={}\\[\\]\\\\|;:'\",.<>/?\\s]+)",
  "indentationRules": {
    "increaseIndentPattern": "^\\s*let\\s+[A-Za-z_][A-Za-z0-9_]*\\s*=\\s*$",
    "decreaseIndentPattern": "^\\s*$"
  }
}
